<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Minimal 1×1 PNG (required image field on payment.method) -->
    <record id="payment_method_euplatesc" model="payment.method">
        <field name="name">EuPlătesc.ro</field>
        <field name="code">EuPlatesc</field>
        <field name="sequence">20</field>
        <field name="image" type="base64" file="payment_euplatesc/static/img/icon.png"/>
        <field name="support_tokenization" eval="False"/>
        <field name="support_express_checkout" eval="False"/>
        <field name="support_manual_capture">none</field>
        <field name="support_refund">partial</field>
    </record>

</odoo>
